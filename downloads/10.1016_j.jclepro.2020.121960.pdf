         <ce:floats>
            <ce:figure id="fig1">
               <ce:label>Fig. 1</ce:label>
               <ce:caption id="cap0010">
                  <ce:simple-para id="fspara0010" view="all">Flow diagram of apple production life cycle from cradle-to-orchard gate, showing system boundary between technosphere (human activity) and ecosphere (nature), as well as the foreground (site specific) and background (generic) systems.</ce:simple-para>
               </ce:caption>
               <ce:alt-text id="alttext0015" role="short">Fig. 1</ce:alt-text>
