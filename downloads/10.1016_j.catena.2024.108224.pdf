   </xocs:meta><xocs:serial-item xmlns:xoe="http://www.elsevier.com/xml/xoe/dtd">
      <article xmlns="http://www.elsevier.com/xml/ja/dtd" docsubtype="fla" xml:lang="en" version="5.6">
         <item-info>
            <jid>CATENA</jid>
            <aid>108224</aid>
            <ce:article-number>108224</ce:article-number>
            <ce:pii>S0341-8162(24)00421-1</ce:pii>
            <ce:doi>10.1016/j.catena.2024.108224</ce:doi>
