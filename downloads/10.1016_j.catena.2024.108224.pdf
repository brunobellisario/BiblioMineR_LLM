                     <ce:grant-number refid="gp010">General 111</ce:grant-number>), and the <ce:grant-sponsor xlink:type="simple" id="gp015" xlink:role="http://www.elsevier.com/xml/linking-roles/grant-sponsor">Basic Research Program of Guizhou Province</ce:grant-sponsor> (ZK [2022] <ce:grant-number refid="gp015">General 098</ce:grant-number>, ZK [2022] <ce:grant-number refid="gp015">General 036</ce:grant-number>, ZK [2022] <ce:grant-number refid="gp015">General 079</ce:grant-number>).</ce:para>
               </ce:section>
               <ce:section id="s0115" view="all">
