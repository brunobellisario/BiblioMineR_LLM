                  </ce:bib-reference>
                  <ce:bib-reference id="b0035">
                     <ce:label>Baselga and Leprieur, 2015</ce:label>
                     <sb:reference id="h0035">
                        <sb:contribution langtype="en">
                           <sb:authors>
                              <sb:author>
                                 <ce:given-name>A.</ce:given-name>
                                 <ce:surname>Baselga</ce:surname>
