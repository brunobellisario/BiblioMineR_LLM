                  <colspec colname="col6"/>
                  <colspec colname="col7"/>
                  <colspec colname="col8"/>
                  <colspec colname="col9"/>
                  <colspec colname="col10"/>
                  <colspec colname="col11"/>
                  <thead>
                     <row valign="top">
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd" rowsep="1" role="colgroup" namest="col1" nameend="col11">Carbon Stock Values</entry>
                     </row>
                     <row rowsep="1" valign="top">
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd" colname="col1">Treat</entry>
