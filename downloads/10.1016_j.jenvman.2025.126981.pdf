                        </ce:figure>
                     </ce:display>
                  </ce:simple-para>
               </ce:abstract-sec>
            </ce:abstract>
            
            <ce:keywords xml:lang="en" id="kwrds0010" class="keyword" view="all">
               <ce:section-title id="sectitle0025">Keywords</ce:section-title>
               <ce:keyword id="kwrd0010">
                  <ce:text>Carbon sequestration</ce:text>
               </ce:keyword>
               <ce:keyword id="kwrd0015">
                  <ce:text>Geographical variation</ce:text>
               </ce:keyword>
               <ce:keyword id="kwrd0020">
                  <ce:text>Growth function</ce:text>
               </ce:keyword>
               <ce:keyword id="kwrd0025">
                  <ce:text>Hierarchical Bayesian model</ce:text>
               </ce:keyword>
               <ce:keyword id="kwrd0030">
                  <ce:text>National forest inventory</ce:text>
               </ce:keyword>
               <ce:keyword id="kwrd0035">
                  <ce:text>Old-growth forest</ce:text>
               </ce:keyword>
            </ce:keywords>
            <ce:data-availability id="da0010" view="all">
