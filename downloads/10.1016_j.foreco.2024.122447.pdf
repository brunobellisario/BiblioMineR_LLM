         <head>
            <ce:title id="tit0005">Post-fire changes in tree diversity, composition and carbon in seasonal forests in the Southern Amazonia</ce:title>
            <ce:author-group id="ag0005">
               <ce:author id="au0005" author-id="S037811272400759X-45bf268169d694cf64451d7749b7e19e">
                  <ce:given-name>Maurivan Barros</ce:given-name>
                  <ce:surname>Pereira</ce:surname>
