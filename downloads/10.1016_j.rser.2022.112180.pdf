                        </ce:e-component>
                     </ce:display>
                  </ce:para>
               </ce:section>
               <ce:section id="appsec2" view="compact-standard">
                  <ce:label>Appendix A</ce:label>
                  <ce:section-title id="sectitle0175">Supplementary data</ce:section-title>
                  <ce:para id="p0630" view="all">Supplementary data to this article can be found online at <ce:inter-ref xlink:href="https://doi.org/10.1016/j.rser.2022.112180" id="intref0020" xlink:type="simple">https://doi.org/10.1016/j.rser.2022.112180</ce:inter-ref>.</ce:para>
