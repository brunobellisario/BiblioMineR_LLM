                                 </row>
                                 <row valign="top">
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Locally migrated</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Dummy</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">1 if respondent has migrated from another village/region</entry>
                                 </row>
                                 <row valign="top">
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Position in village committee</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Dummy</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">1 if respondent has position in any village committee</entry>
                                 </row>
                                 <row valign="top">
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Forest income</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Numeric</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Income generated from selling forest products in USD</entry>
                                 </row>
                                 <row valign="top">
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Annual sale of crops produced</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Dummy</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">1 if more than half of crops produced are sold.</entry>
                                 </row>
                                 <row valign="top">
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Farmland size</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Numeric</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Parcel of land in hectare</entry>
                                 </row>
                                 <row valign="top">
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Expect increases in forest use</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Dummy</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">1 if respondent expected use of forest to increase in the future</entry>
                                 </row>
                                 <row valign="top">
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Household socioeconomic shocks</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Dummy</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">1 if respondent has faced any socio-economic shocks</entry>
                                 </row>
                                 <row valign="top">
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Conflict over farmland access</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Dummy</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">1 if respondent has experienced any conflict over access for farmland</entry>
                                 </row>
                                 <row valign="top">
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Climate change awareness</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Dummy</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">1 if respondent is aware of the climate change or its impact</entry>
                                 </row>
                              </tbody>
                           </tgroup>
                        </ce:table>
                     </ce:display>
                  </ce:para>
               </ce:section>
            </ce:appendices>
