                              <colspec colnum="3" colname="col3"/>
                              <thead>
                                 <row rowsep="1" valign="top">
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd">Variables</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd">Measurement</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd">Description</entry>
                                 </row>
                              </thead>
                              <tbody>
                                 <row valign="top">
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left" role="rowhead colgroup" namest="col1" nameend="col3">
                                       <italic>Demographic and socioeconomic</italic>
                                    </entry>
                                 </row>
                                 <row valign="top">
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Gender (=male)</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Dummy</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">1 if respondent is male</entry>
                                 </row>
                                 <row valign="top">
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Age</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Numeric</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Age of the respondent</entry>
                                 </row>
                                 <row valign="top">
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Formal education</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Dummy</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">1 if respondent has any formal education</entry>
                                 </row>
                                 <row valign="top">
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Family size</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Numeric</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Number of individuals in the family</entry>
                                 </row>
                                 <row valign="top">
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Ethnicity (=Mongo)</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="left">Dummy</entry>
