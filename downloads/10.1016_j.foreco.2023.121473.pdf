               </ce:affiliation>
               <ce:correspondence id="cor1">
                  <ce:label>⁎</ce:label>
                  <ce:text>Corresponding author at: Department of Silviculture and Forest Ecology of the Temperate Zones, Faculty of Forest Sciences, University of Göttingen, Büsgenweg 1, 37077 Göttingen, Germany.</ce:text>
                  <sa:affiliation>
                     <sa:organization>Department of Silviculture and Forest Ecology of the Temperate Zones</sa:organization>
                     <sa:organization>Faculty of Forest Sciences</sa:organization>
                     <sa:organization>University of Göttingen</sa:organization>
                     <sa:address-line>Büsgenweg 1</sa:address-line>
                     <sa:city>Göttingen</sa:city>
