   </xocs:meta><xocs:serial-item xmlns:xoe="http://www.elsevier.com/xml/xoe/dtd">
      <article xmlns="http://www.elsevier.com/xml/ja/dtd" version="5.7" docsubtype="fla" xml:lang="en">
         <item-info>
            <jid>BIOC</jid>
            <aid>111765</aid>
            <ce:article-number>111765</ce:article-number>
            <ce:pii>S0006-3207(26)00073-X</ce:pii>
