         <head>
            <ce:dochead id="dh0005">
               <ce:textfn id="tn0005">Research article</ce:textfn>
            </ce:dochead>
            <ce:title id="ti0005">A 30-year population decline of a threatened forest orchid associated with old growth forests</ce:title>
            <ce:author-group id="ag0005">
               <ce:author id="au0005" author-id="S000632072600073X-e1070a2aa6aaaaf36fee42d0a68f4995">
                  <ce:given-name>Victor</ce:given-name>
