                        <entry xmlns="http://www.elsevier.com/xml/common/dtd"/>
                     </row>
                     <row valign="top">
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd">Campaegli</entry>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd">0.806</entry>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd">0.361</entry>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd">2.235</entry>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd">0.02542</entry>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd">*</entry>
                     </row>
                     <row valign="top">
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd">CPA</entry>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd">−0.229</entry>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd">0.143</entry>
