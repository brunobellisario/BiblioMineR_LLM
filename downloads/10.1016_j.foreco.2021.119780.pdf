                                       <mml:mn>1</mml:mn>
                                       <mml:mo>,</mml:mo>
                                       <mml:mo>⋯</mml:mo>
                                       <mml:mo>,</mml:mo>
                                       <mml:mi>n</mml:mi>
                                       <mml:mo stretchy="false">)</mml:mo>
                                    </mml:mrow>
                                 </mml:mrow>
                              </mml:math>
                           </ce:formula>
                        </ce:display>where: <mml:math altimg="si10.svg">
                           <mml:msub>
                              <mml:mrow>
                                 <mml:mi mathvariant="italic">PAR</mml:mi>
                              </mml:mrow>
                              <mml:mrow>
                                 <mml:mi mathvariant="italic">un</mml:mi>
                              </mml:mrow>
                           </mml:msub>
                        </mml:math> is the value of a given structural parameter in unmanaged stands; <mml:math altimg="si12.svg">
                           <mml:msub>
                              <mml:mrow>
                                 <mml:mi mathvariant="italic">PAR</mml:mi>
                              </mml:mrow>
                              <mml:mrow>
                                 <mml:mi mathvariant="italic">co</mml:mi>
                              </mml:mrow>
                           </mml:msub>
                        </mml:math> is the value of a given structural parameter in stands with combined management; <mml:math altimg="si16.svg">
                           <mml:msub>
                              <mml:mrow>
                                 <mml:mi mathvariant="italic">dPAR</mml:mi>
                              </mml:mrow>
                              <mml:mrow>
                                 <mml:mi>u</mml:mi>
                                 <mml:mi>n</mml:mi>
                                 <mml:mi>_</mml:mi>
