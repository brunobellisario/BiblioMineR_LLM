               <ce:label>Fig. 1</ce:label>
               <ce:caption id="cap0008">
                  <ce:simple-para id="spara001" view="all">Map showing study corridors and buffer zones in Terai Arc Landscape.</ce:simple-para>
               </ce:caption>
               <ce:alt-text id="alt0008" role="short">Fig 1:</ce:alt-text>
               <ce:link id="celink0001" locator="gr1" xlink:type="simple" xlink:role="http://data.elsevier.com/vocabulary/ElsevierContentTypes/23.4" xlink:href="pii:S2666719324002346/gr1"/>
            </ce:figure>
            <ce:figure id="fig0002">
               <ce:label>Fig. 2</ce:label>
               <ce:caption id="cap0009">
                  <ce:simple-para id="spara002" view="all">Four circular plots within a cluster of concentric circular sample plots where trees with dbh ≥ 30 cm were measured in r1, 20 cm to &lt;30 cm dbh in r2, 10 cm to &lt;20 cm in r3 and 5 cm to &lt;10 cm in r4.</ce:simple-para>
               </ce:caption>
               <ce:alt-text id="alt0009" role="short">Fig 2:</ce:alt-text>
               <ce:link id="celink0002" locator="gr2" xlink:type="simple" xlink:role="http://data.elsevier.com/vocabulary/ElsevierContentTypes/23.4" xlink:href="pii:S2666719324002346/gr2"/>
            </ce:figure>
