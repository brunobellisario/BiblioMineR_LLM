               <ce:label>Fig. 3</ce:label>
               <ce:caption id="cap0010">
                  <ce:simple-para id="spara003" view="all">Forest inventory plot distribution map in different study sites.</ce:simple-para>
               </ce:caption>
               <ce:alt-text id="alt0010" role="short">Fig 3:</ce:alt-text>
               <ce:link id="celink0003" locator="gr3" xlink:type="simple" xlink:role="http://data.elsevier.com/vocabulary/ElsevierContentTypes/23.4" xlink:href="pii:S2666719324002346/gr3"/>
