         <head>
            <ce:title id="tte0002">Tree species diversity and spatial distribution of carbon stock in forests under different management regimes in Nepal's Western Terai Arc Landscape</ce:title>
            <ce:author-group id="aut0001">
               <ce:author id="au0001" author-id="S2666719324002346-5bbdd957646b32257717f3ba0050880b" orcid="0000-0003-2654-5108">
