                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd">Old-Growthiness Indicator</entry>
                                 </row>
                                 <row valign="top">
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd">OP</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd">Overmature Phase</entry>
                                 </row>
                                 <row valign="top">
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd">Perc10</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd">10th Percentile</entry>
                                 </row>
                                 <row valign="top">
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd">Perc90</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd">90th Percentile</entry>
                                 </row>
