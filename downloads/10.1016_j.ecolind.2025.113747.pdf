         <ce:floats>
            <ce:figure id="f0005">
               <ce:label>Fig. 1</ce:label>
               <ce:caption id="cn0005">
                  <ce:simple-para id="sp0025" view="all">Map of the study area. (A) The location of Białowieża National Park within Poland, with light green indicating forested areas and dark green representing national parks. (B) Locations of the five study sites and 20 survey plots. Colours indicate forest types; the Orłówka River is marked in blue. Forest cover data were obtained from Geoportal.gov.pl, national park boundaries from the General Directorate for Environmental Protection, and habitat cover data from The Forest Data Bank (<ce:inter-ref xlink:href="https://www.bdl.lasy.gov.pl/" xlink:type="simple" id="ir005">https://www.bdl.lasy.gov.pl/</ce:inter-ref>).</ce:simple-para>
               </ce:caption>
               <ce:link locator="gr1" xlink:type="simple" xlink:role="http://data.elsevier.com/vocabulary/ElsevierContentTypes/23.4" xlink:href="pii:S1470160X25006776/gr1" id="lk00005"/>
            </ce:figure>
            <ce:figure id="f0010">
               <ce:label>Fig. 2</ce:label>
               <ce:caption id="cn0010">
                  <ce:simple-para id="sp0030" view="all">Pearson's correlation coefficients (r) and associated p-values (p) between the cumulative and survey level alpha richness detected with each method. Significant values (p &lt; 0.05) are in bold.</ce:simple-para>
               </ce:caption>
               <ce:link locator="gr2" xlink:type="simple" xlink:role="http://data.elsevier.com/vocabulary/ElsevierContentTypes/23.4" xlink:href="pii:S1470160X25006776/gr2" id="lk00010"/>
            </ce:figure>
            <ce:figure id="f0015">
               <ce:label>Fig. 3</ce:label>
               <ce:caption id="cn0015">
                  <ce:simple-para id="sp0035" view="all">Changes in alpha richness across the five main sites and all sampling methods throughout the breeding season. Curves were modelled using the loess method, with the shaded area representing a 95% confidence interval.</ce:simple-para>
               </ce:caption>
               <ce:link locator="gr3" xlink:type="simple" xlink:role="http://data.elsevier.com/vocabulary/ElsevierContentTypes/23.4" xlink:href="pii:S1470160X25006776/gr3" id="lk00015"/>
            </ce:figure>
            <ce:figure id="f0020">
               <ce:label>Fig. 4</ce:label>
               <ce:caption id="cn0020">
                  <ce:simple-para id="sp0040" view="all">Cumulative beta diversity across five main sites using different sampling methods, displayed as a Non-metric Multidimensional Scaling (NMDS) plot with Bray-Curtis dissimilarity. Ellipses represent 95 % confidence intervals of clusters identified through k-means clustering (k = 3).</ce:simple-para>
               </ce:caption>
               <ce:link locator="gr4" xlink:type="simple" xlink:role="http://data.elsevier.com/vocabulary/ElsevierContentTypes/23.4" xlink:href="pii:S1470160X25006776/gr4" id="lk00020"/>
            </ce:figure>
            <ce:figure id="f0025">
               <ce:label>Fig. 5</ce:label>
               <ce:caption id="cn0025">
                  <ce:simple-para id="sp0045" view="all">Mean and maximum confidence scores for each species obtained during the analysis of BN ALL data. Numbers in brackets are the number of surveys at which each species was detected.</ce:simple-para>
               </ce:caption>
               <ce:link locator="gr5" xlink:type="simple" xlink:role="http://data.elsevier.com/vocabulary/ElsevierContentTypes/23.4" xlink:href="pii:S1470160X25006776/gr5" id="lk00025"/>
            </ce:figure>
            <ce:table xmlns="http://www.elsevier.com/xml/common/cals/dtd" frame="topbot" id="t0005" rowsep="0" colsep="0">
               <ce:label>Table 1</ce:label>
               <ce:caption id="cn0030">
                  <ce:simple-para id="sp0050" view="all">Results of the model investigating differences in cumulative alpha richness detected by each method over the entire season, using BN-ALL as the reference. Significant values are in bold (p &lt; 0.05).</ce:simple-para>
               </ce:caption>
