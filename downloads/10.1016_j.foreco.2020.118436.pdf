         <head>
            <ce:title id="tm005">Using lichen communities as indicators of forest stand age and conservation value</ce:title>
            <ce:author-group id="ag005">
               <ce:author id="au005" author-id="S0378112720312056-7967dbb5d3d5515bc756aab8126c0fbc">
