         </body>
         <tail view="all">
            <ce:bibliography id="bi005" view="all">
               <ce:section-title id="st140">References</ce:section-title>
               <ce:bibliography-sec id="bs005" view="all">
                  <ce:bib-reference id="b0005">
                     <ce:label>Aguilar et al., 2014</ce:label>
                     <sb:reference id="h0005">
                        <sb:contribution langtype="en">
                           <sb:authors>
                              <sb:author>
                                 <ce:given-name>L.M.S.</ce:given-name>
                                 <ce:surname>Aguilar</ce:surname>
                              </sb:author>
                              <sb:author>
                                 <ce:given-name>E.</ce:given-name>
                                 <ce:surname>Bernard</ce:surname>
                              </sb:author>
                              <sb:author>
                                 <ce:given-name>R.B.</ce:given-name>
                                 <ce:surname>Machado</ce:surname>
                              </sb:author>
                           </sb:authors>
                           <sb:title>
                              <sb:maintitle>Habitat use and movements of <ce:italic>Glossophaga soricina</ce:italic> and <ce:italic>Lonchophylla dekeyseri</ce:italic> (Chiroptera: Phyllostomidae) in a Neotropical savannah</sb:maintitle>
                           </sb:title>
