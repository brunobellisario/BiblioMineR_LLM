                        <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="char" char=".">35.883</entry>
                     </row>
                     <row>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd" role="rowhead">Missing rings (%)</entry>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd">81</entry>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd">280 (47–1118)</entry>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd">Height (10–50 m)</entry>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd">4</entry>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="char" char=".">97.974</entry>
                     </row>
                     <row>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd" role="rowhead">Missing rings (%)</entry>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd">44</entry>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd">65 (16–161)</entry>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd">Height (1.4–70 m)</entry>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd">7</entry>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="char" char=".">30.919</entry>
                     </row>
                     <row>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd" role="rowhead">Interseries correlation (<italic>r</italic>)</entry>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd">103</entry>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd">170 (30–492)</entry>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd">Height (10–50 m)</entry>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd">4</entry>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="char" char=".">174.86</entry>
                     </row>
                     <row>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd" role="rowhead">Interseries correlation (<italic>r</italic>)</entry>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd">58</entry>
