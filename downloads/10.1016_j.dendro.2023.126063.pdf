                        <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="char" char=".">159.17</entry>
                     </row>
                     <row>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd" role="rowhead">Ring width (mm)</entry>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd">103</entry>
