                        <entry xmlns="http://www.elsevier.com/xml/common/dtd">4</entry>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="char" char=".">60.906</entry>
                     </row>
                     <row>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd" role="rowhead">Undated rings (%)</entry>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd">27</entry>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd">98 (24–191)</entry>
