   </xocs:meta><xocs:serial-item xmlns:xoe="http://www.elsevier.com/xml/xoe/dtd">
      <article xmlns="http://www.elsevier.com/xml/ja/dtd" docsubtype="fla" xml:lang="en" version="5.7">
         <item-info>
            <jid>FORECO</jid>
            <aid>123148</aid>
            <ce:article-number>123148</ce:article-number>
            <ce:pii>S0378-1127(25)00656-5</ce:pii>
