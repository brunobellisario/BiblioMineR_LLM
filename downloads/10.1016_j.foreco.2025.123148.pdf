         <head>
            <ce:title id="tit0005">Two decades of forest understory vegetation development in a 445-year chronosequence in the Siskiyou mountains of southwestern Oregon, USA</ce:title>
            <ce:author-group id="ag0005">
               <ce:author id="au0005" author-id="S0378112725006565-3ce8119541659746ca8a128542663b5a" orcid="0009-0008-5940-7186">
