                     <ce:source-text id="srct0030">Aas, G., 1991. Kreuzungsversuche mit Stiel- und Traubeneichen (Quercus robur L. und Quercus petraea Matt. Liebl.). Allg. Forst. Jagdztg. 162, 141-145.</ce:source-text>
                  </ce:bib-reference>
                  <ce:bib-reference id="bib2">
                     <ce:label>Albrich et al., 2020</ce:label>
                     <sb:reference id="sref2">
                        <sb:contribution langtype="en">
                           <sb:authors>
