            </ce:acknowledgment>
            <ce:appendices view="all">
               <ce:section id="appsec1" view="extended">
                  <ce:label>Appendix A</ce:label>
                  <ce:section-title id="sectitle0145">Supplementary data</ce:section-title>
                  <ce:para id="p0210" view="all">The following is/are the supplementary data to this article.<ce:display>
