         <head>
            <ce:title id="title0010">Tree sapling vitality and recovery following the unprecedented 2018 drought in central Europe</ce:title>
            <ce:author-group id="augrp0010">
               <ce:author id="au1" orcid="0000-0002-3592-8170" author-id="S2197562023000714-bc3f06d0146c8f1bf2ac5995e4006e9f">
