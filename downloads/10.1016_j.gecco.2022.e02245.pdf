                                 </row>
                                 <row>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" role="rowhead">50-m CL</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd"/>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="char" char="."/>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd"/>
