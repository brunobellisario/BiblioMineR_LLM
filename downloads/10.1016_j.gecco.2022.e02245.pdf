                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd"/>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd"/>
                                 </row>
                                 <row>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" role="rowhead">DTM</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd">CL</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="char" char=".">114.6</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd">267.6–377.7</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd">&lt; 0.001</entry>
                                 </row>
                                 <row>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" role="rowhead"/>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd">whole study site</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="char" char=".">109.3</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd"/>
