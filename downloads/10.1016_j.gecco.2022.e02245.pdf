               <ce:section id="sec0070" view="all">
                  <ce:label>Appendix 4</ce:label>
                  <ce:section-title id="sect0095">Results of Welch’s <ce:italic>t</ce:italic>-test assessing the difference in forest vertical components (FVCs: DTM, digital terrain model; DSM, digital surface model; CH, canopy height) between calling locations and the whole study site depending upon calling location (CL) size (20-, 50-, 100-, 150-m radius). We compared 3000 randomly selected samplings from each CL and the whole study site five times, such that the mean of each FVC represents 3000 × 5 samples</ce:section-title>
                  <ce:para id="p0275" view="all">
                     <ce:display>
                        <ce:table xmlns="http://www.elsevier.com/xml/common/cals/dtd" id="tbl0030" colsep="0" rowsep="0" frame="topbot">
                           <ce:alt-text id="at0060" role="short">Table</ce:alt-text>
                           <tgroup cols="5">
                              <colspec colnum="1" colname="col1"/>
