                        <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="char" char=".">0.12</entry>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="char" char=".">− 0.69</entry>
                     </row>
                     <row>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd" role="rowhead">CH</entry>
