                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd">CL</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="char" char=".">138.3</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd">303.2–441.0</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd">&lt; 0.001</entry>
                                 </row>
                                 <row>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" role="rowhead"/>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd">whole study site</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="char" char=".">130.6</entry>
