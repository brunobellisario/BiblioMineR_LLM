                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd">CL</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" align="char" char=".">23.8</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd">85.3–158.0</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd">&lt; 0.001</entry>
