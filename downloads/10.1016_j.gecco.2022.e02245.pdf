            </ce:table>
            <ce:table xmlns="http://www.elsevier.com/xml/common/cals/dtd" id="tbl0015" colsep="0" rowsep="0" frame="topbot">
               <ce:label>Table 3</ce:label>
               <ce:caption id="cap0040">
                  <ce:simple-para id="sp0040" view="all">Comparison of average PCA scores of each sub-block among three different land-use types.</ce:simple-para>
               </ce:caption>
               <ce:alt-text id="at0040" role="short">Table 3</ce:alt-text>
               <tgroup cols="5">
                  <colspec colnum="1" colname="col1"/>
                  <colspec colnum="2" colname="col2"/>
                  <colspec colnum="3" colname="col3"/>
                  <colspec colnum="4" colname="col4"/>
                  <colspec colnum="5" colname="col5"/>
                  <thead>
                     <row rowsep="1">
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd">Land-use types</entry>
                        <entry xmlns="http://www.elsevier.com/xml/common/dtd">
                           <italic>n</italic>
                        </entry>
