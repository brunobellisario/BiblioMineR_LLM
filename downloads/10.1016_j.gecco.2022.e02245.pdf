                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd">
                                       <italic>F</italic>-value<sup loc="post">1</sup>)</entry>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd">
                                       <italic>P</italic>-value</entry>
                                 </row>
                              </thead>
                              <tbody>
                                 <row>
                                    <entry xmlns="http://www.elsevier.com/xml/common/dtd" role="rowhead">20-m CL</entry>
