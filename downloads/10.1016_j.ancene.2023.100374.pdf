            </xocs:item-toc-entry>
            <xocs:item-toc-entry ref-elem="ce:sections">
               <xocs:item-toc-label>4.3</xocs:item-toc-label>
               <xocs:item-toc-section-title>Assessment of land-use and land-cover changes</xocs:item-toc-section-title>
