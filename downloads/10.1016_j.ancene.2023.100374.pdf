         <head>
            <ce:title id="tit0005">Spatio-temporal dynamics of forest ecosystems revealed by the LiDAR-based characterization of medieval field systems (Vosges Mountains, France)</ce:title>
            <ce:author-group id="ag0005">
               <ce:author id="au0005" author-id="S2213305423000073-e34f61fd631385b5dc714877ccb8265c" orcid="0000-0002-6798-1427">
                  <ce:given-name>Benjamin</ce:given-name>
                  <ce:surname>Keller</ce:surname>
