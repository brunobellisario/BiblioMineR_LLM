                     <sa:country>France</sa:country>
                  </sa:affiliation>
                  <ce:source-text id="srct0010">Laboratoire Image, Ville, Environnement (LIVE) – UMR 7362, CNRS – University of Strasbourg, 3 rue de l’Argonne, 67000 Strasbourg, France.</ce:source-text>
               </ce:affiliation>
               <ce:affiliation id="aff0010" affiliation-id="S2213305423000073-3bf249a763accedb0a85953d7bb676dc">
                  <ce:label>b</ce:label>
                  <ce:textfn>Ecole Nationale du Génie de l’Eau et de l’Environnement de Strasbourg (ENGEES), 1 quai Koch, 67000 Strasbourg, France</ce:textfn>
                  <sa:affiliation>
                     <sa:organization>Ecole Nationale du Génie de l’Eau et de l’Environnement de Strasbourg (ENGEES)</sa:organization>
